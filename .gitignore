# Ignore everything by default
/*

# But track these specific project folders
!/luvlang-mastering/
!/luvlang-backend/
!/luvlang-production-clean/

# Track important config files
!.gitignore
!.gitattributes
!railway.json
!index.html
!vercel.json
!luvlang_LEGENDARY_COMPLETE.html

# Ignore common directories
.DS_Store
node_modules/
dist/
build/
*.log
.env
.env.*
*.sqlite
*.db

# Ignore system directories
.Trash/
Library/
Applications/
Desktop/
Documents/
Downloads/
Movies/
Music/
Pictures/
Public/
.cache/
.npm/
.config/
.local/
.ssh/
.vscode/
.docker/
.n8n/
.railway/
